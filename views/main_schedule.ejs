<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>LCK - Lịch Thi Đấu</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <header class="lck-header">
            <div class="nav-left">
                <a href="/"><img src="/assets/images/lck.png" alt="LCK" class="logo-img"></a>
                <nav class="nav-links">
                    <a href="/">TRANG CHỦ</a>
                    <a href="/lich-thi-dau" class="active">LỊCH THI ĐẤU</a>
                    <a href="/bang-xep-hang">BẢNG XẾP HẠNG</a>
                    <a href="#">DANH SÁCH ▼</a>
                </nav>
            </div>
            <div class="nav-right">
                <% if (user) { %>
                    <span style="margin-right: 15px; font-family: 'Montserrat', sans-serif;">
                        <%= user.role === 'admin' ? 'Admin' : 'User' %>: <%= user.username %>
                    </span>
                    <a href="/logout" class="btn-login" style="background:#e74c3c; color:white;">ĐĂNG XUẤT</a>
                <% } else { %>
                    <a href="/login" class="btn-login">ĐĂNG NHẬP</a>
                <% } %>
            </div>
        </header>

        <div class="date-bar">
            <h2 id="display-date-text">ĐANG TẢI...</h2>
            
            <div class="date-nav-pill">
    <button onclick="changeDate(-1)">◀</button>
    
    <div style="display: flex; align-items: center; justify-content: center; min-width: 120px;">
        <span id="quick-date-display" style="font-size:18px; font-weight:bold; color:white; text-transform: uppercase;">
            HÔM NAY
        </span>
    </div>

    <button onclick="changeDate(1)">▶</button>
</div>

            <button class="btn-notify" onclick="openNotifyModal()">NHẬN THÔNG BÁO 🔔</button>
        </div> <div class="match-list">
            <% if(fixtures.length > 0) { %>
                <% fixtures.forEach(match => { %>
                    <div class="match-card" onclick="followMatch('<%= match.c1_n %> vs <%= match.c2_n %>')">
                        <div class="match-time">12:00</div>
                        
                        <div class="team-block home">
                            <span class="team-name"><%= match.c1_n %></span>
                            <img src="/assets/images/<%= match.c1_l %>" class="team-logo">
                        </div>
                        
                        <div class="match-score">
                            <% if (user && user.role === 'admin') { %>
                                <div onclick="event.stopPropagation()">
                                    <input type="number" id="h-<%= match.fixture_id %>" value="<%= match.home_score %>" style="width:40px; font-size:24px; text-align:center;">
                                    /
                                    <input type="number" id="a-<%= match.fixture_id %>" value="<%= match.away_score %>" style="width:40px; font-size:24px; text-align:center;">
                                    <button onclick="saveScore('<%= match.fixture_id %>')" style="font-family:'Oswald'; cursor:pointer; font-size: 16px;">LƯU</button>
                                </div>
                            <% } else { %>
                                <%= match.is_finished ? match.home_score : '' %> 
                                <span style="color: #000;">/</span> 
                                <%= match.is_finished ? match.away_score : '' %>
                            <% } %>
                        </div>
                        
                        <div class="team-block away">
                            <img src="/assets/images/<%= match.c2_l %>" class="team-logo">
                            <span class="team-name"><%= match.c2_n %></span>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <h3 style="text-align: center; font-family: 'Montserrat', sans-serif; color: #888; margin-top: 50px;">Không có trận đấu nào trong ngày này.</h3>
            <% } %>
        </div>
    </div>

    <div id="notifyModal" class="modal-overlay" style="display: none;">
        <div class="modal-content">
            <h3>CHỌN ĐỘI THEO DÕI 🔔</h3>
            <p style="font-family: 'Montserrat'; font-size: 14px; margin-bottom: 20px;">Nhận thông báo lịch thi đấu và kết quả</p>
            <div class="team-list-check">
                <label><input type="checkbox" value="T1"> Đội tuyển T1</label>
                <label><input type="checkbox" value="GEN.G"> Đội tuyển GEN.G</label>
                <label><input type="checkbox" value="HLE"> Đội tuyển HLE</label>
                <label><input type="checkbox" value="DK"> Đội tuyển DK</label>
                <label><input type="checkbox" value="FEAX"> Đội tuyển FEAX</label>
                <label><input type="checkbox" value="DNS"> Đội tuyển DNS</label>
                <label><input type="checkbox" value="BNK"> Đội tuyển BNK</label>
                <label><input type="checkbox" value="BRO"> Đội tuyển BRO</label>
                <label><input type="checkbox" value="DRX"> Đội tuyển DRX</label>
                <label><input type="checkbox" value="KDF"> Đội tuyển KDF</label>
                <label><input type="checkbox" value="KT"> Đội tuyển KT</label>
                <label><input type="checkbox" value="NS"> Đội tuyển NS</label>
            </div>
            <button class="btn-save-modal" onclick="confirmNotify()">LƯU LỰA CHỌN</button><br>
            <button class="btn-close-modal" onclick="closeNotifyModal()">Hủy bỏ</button>
        </div>
    </div>

<script>
    // 1. Dùng window.dateObj để tránh hoàn toàn lỗi Cannot redeclare (Ln 96, Ln 123)
    var serverDate = '<%= currentDate %>'; 
    var dateParts = serverDate.split('-'); 
    window.dateObj = new Date(dateParts[0], dateParts[1] - 1, dateParts[2]);

    // 2. Hiển thị Thứ, Ngày, Tháng
    var days = ['CHỦ NHẬT', 'THỨ HAI', 'THỨ BA', 'THỨ TƯ', 'THỨ NĂM', 'THỨ SÁU', 'THỨ BẢY'];
    document.getElementById('display-date-text').textContent = 
        `${days[window.dateObj.getDay()]}, ${window.dateObj.getDate()} THÁNG ${window.dateObj.getMonth() + 1}`;

    // 3. Cập nhật nhãn "HÔM NAY / NGÀY MAI / X NGÀY SAU"
    function updateQuickDateText() {
        var realToday = new Date();
        realToday.setHours(0, 0, 0, 0);

        var viewingDate = new Date(window.dateObj); 
        viewingDate.setHours(0, 0, 0, 0);

        var diffTime = viewingDate - realToday;
        var diffDays = Math.round(diffTime / (1000 * 60 * 60 * 24));

        var quickDateText = "";
        if (diffDays === 0) quickDateText = "HÔM NAY";
        else if (diffDays === 1) quickDateText = "NGÀY MAI";
        else if (diffDays === -1) quickDateText = "HÔM QUA";
        else if (diffDays > 1) quickDateText = `${diffDays} NGÀY SAU`;
        else quickDateText = `${Math.abs(diffDays)} NGÀY TRƯỚC`;

        var todayBtn = document.getElementById('quick-date-display');
        if (todayBtn) todayBtn.textContent = quickDateText;
        
        var picker = document.getElementById('calendar-picker');
        if (picker) picker.value = serverDate;
    }
    updateQuickDateText();

    // 4. Hàm đổi ngày qua lại
    function changeDate(offset) {
        var newDate = new Date(window.dateObj);
        newDate.setDate(newDate.getDate() + offset);
        var yyyy = newDate.getFullYear();
        var m = String(newDate.getMonth() + 1).padStart(2, '0');
        var d = String(newDate.getDate()).padStart(2, '0');
        window.location.href = `/lich-thi-dau?date=${yyyy}-${m}-${d}`;
    }

    // 5. Modal & Follow
    function openNotifyModal() { document.getElementById('notifyModal').style.display = 'flex'; }
    function closeNotifyModal() { document.getElementById('notifyModal').style.display = 'none'; }
    function confirmNotify() { alert("✅ Đã lưu cài đặt nhận thông báo!"); closeNotifyModal(); }
    function followMatch(matchName) { alert(`🔔 Bạn đã đăng ký nhận thông báo cho trận: ${matchName}`); }

    // 6. Admin lưu điểm
    function saveScore(id) {
        var h = document.getElementById('h-'+id).value;
        var a = document.getElementById('a-'+id).value;
        fetch('/update-score', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({fixtureId: id, homeScore: h, awayScore: a})
        }).then(() => location.reload());
    }
</script>
</body>
</html>